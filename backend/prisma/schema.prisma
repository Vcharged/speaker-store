generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  firstName String
  lastName  String
  birthDate DateTime
  phone     String    @default("")
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

enum ProductCategory {
  SPEAKER
  INSTRUMENT
}

model Product {
  id          String         @id @default(uuid())
  category    ProductCategory
  brand       String
  model       String
  description String         @default("")
  photoUrl    String         @default("")
  price       Float
  isAvailable Boolean        @default(true)
  createdAt   DateTime       @default(now())
  bookings    Booking[]
}

model Booking {
  id         String        @id @default(uuid())
  userId     String
  productId  String
  startDate  DateTime
  endDate    DateTime
  totalPrice Float
  status     BookingStatus @default(PENDING)

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([productId])
}
