{$DOMAIN} {
  encode gzip zstd

  # API запросы пробрасываем как есть, без обрезания /api
  handle /api/* {
    reverse_proxy backend:3000
  }

  # Отдача загруженных файлов
  handle /uploads/* {
    reverse_proxy backend:3000
  }

  # Всё остальное — SPA фронтенд
  handle {
    root * /srv
    try_files {path} /index.html
    file_server
  }
}
